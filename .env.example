# Gemini API Key (Google AI Studio で取得)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Cloudflare API Token (alchemy deploy に必要、ローカル開発では不要)
# https://dash.cloudflare.com/profile/api-tokens
# 必要な権限: Workers Scripts Edit, D1 Edit, R2 Edit
CLOUDFLARE_API_TOKEN=

CLOUDFLARE_ACCOUNT_ID=

CLOUDFLARE_EMAIL=

# Alchemy Secret 暗号化パスワード (alchemy.secret() に必要、ローカル開発では不要)
# 任意の文字列を設定
ALCHEMY_PASSWORD=

ALCHEMY_STATE_TOKEN=

