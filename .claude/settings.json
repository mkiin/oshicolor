{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": false,
  "language": "japanese",
  "attribution": {
  "commit": ""
  },
  "env":{
    "CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "DISABLE_TELEMETRY": "1",
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(pnpm *)",
      "Bash(ls*)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(date)",
      "Bash(uname *)",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(pnpm install*)",
      "Bash(pnpm i)",
      "Bash(pnpm i *)",
      "Bash(pnpm add*)"
    ]
  }
}
