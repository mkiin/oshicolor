{
  "include": [
    "src/**/*.tsx",
    "src/**/*.ts",
    "tests/**/*.ts",
    "alchemy.run.ts",
    "packages/*/src/**/*.ts"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "./src/types/env.d.ts"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@oshicolor/color": ["./packages/color/src/index.ts"],
      "@oshicolor/image": ["./packages/image/src/index.ts"],
      "@oshicolor/core": ["./packages/core/src/index.ts"]
    }
  }
}
